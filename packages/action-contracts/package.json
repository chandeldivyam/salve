{
  "name": "@salve/action-contracts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src/**/*.ts"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./customers": "./src/customers.ts",
