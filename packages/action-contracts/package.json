    "./views": "./src/views.ts"
  },
  "scripts": {
    "type-check": "tsc -p tsconfig.json --noEmit",
    "format": "biome format --write .",
    "check": "biome check ."
  },
  "dependencies": {
    "zod": "4.4.1"
  }
}
