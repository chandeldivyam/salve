{
  "name": "salve",
  "private": true,
  "version": "0.0.0",
  "description": "Salve — open-source Intercom/Zendesk alternative.",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev --parallel --filter=@salve/api --filter=@salve/web --filter=@salve/zero-cache --filter=@salve/marketing",
    "dev:docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "dev:docker:down": "docker compose -f docker/docker-compose.yml down",
    "dev:docker:logs": "docker compose -f docker/docker-compose.yml logs -f",
    "dev:clean": "docker compose -f docker/docker-compose.yml down -v && rm -f zero.db zero.db-* sync-replica.db sync-replica.db-*",
    "build": "turbo run build",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "check:file-sizes": "node scripts/check-file-sizes.mjs",
    "db:generate": "pnpm --filter @salve/db db:generate",
    "db:migrate": "pnpm --filter @salve/db db:migrate",
    "db:push": "pnpm --filter @salve/db db:push",
    "db:studio": "pnpm --filter @salve/db db:studio",
    "db:seed:scale": "pnpm --filter @salve/db db:seed:scale",
    "sst:deploy:staging": "sst deploy --stage staging",
    "sst:deploy:prod": "sst deploy --stage prod",
    "sst:remove:staging": "sst remove --stage staging",
    "sst:diff:prod": "sst diff --stage prod",
    "sst:diff:staging": "sst diff --stage staging"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@types/node": "25.6.0",
    "sst": "^4.13.1",
    "turbo": "2.9.6",
    "typescript": "6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@rocicorp/zero-sqlite3",
      "protobufjs"
    ]
  }
}
