{
  "name": "@opendesk/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "format": "biome format --write .",
    "check": "biome check ."
  },
  "dependencies": {
    "@hono/node-server": "2.0.0",
    "@opendesk/core": "workspace:*",
    "@opendesk/db": "workspace:*",
    "@opendesk/mutators": "workspace:*",
    "@opendesk/zero-schema": "workspace:*",
    "better-auth": "1.6.9",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.15",
    "jose": "6.2.3",
    "postgres": "3.4.9",
    "zod": "4.4.1"
  },
  "devDependencies": {
    "tsx": "4.21.0"
  }
}
