{
  "name": "@salve/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "format": "biome format --write .",
    "check": "biome check ."
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.957.0",
    "@aws-sdk/client-sesv2": "3.1039.0",
    "@aws-sdk/s3-request-presigner": "3.957.0",
    "@better-auth/api-key": "1.6.9",
    "@hono/node-server": "2.0.0",
    "@salve/action-contracts": "workspace:*",
    "@salve/action-executor": "workspace:*",
    "@salve/core": "workspace:*",
    "@salve/db": "workspace:*",
    "@salve/mutators": "workspace:*",
    "@salve/zero-schema": "workspace:*",
    "@rocicorp/zero": "1.3.0",
    "better-auth": "1.6.9",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.15",
    "inngest": "4.2.6",
    "jose": "6.2.3",
    "mailparser": "3.9.8",
    "nanoid": "5.1.9",
    "nodemailer": "8.0.7",
    "postgres": "3.4.9",
    "zod": "4.4.1"
  },
  "devDependencies": {
    "@types/mailparser": "3.4.6",
    "@types/nodemailer": "8.0.0",
    "tsx": "4.21.0"
  }
}
