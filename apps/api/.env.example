# Hono API server
PORT=3001

# Postgres (Phase 1+)
DATABASE_URL=postgres://opendesk_app:opendesk_app@localhost:5432/opendesk

# better-auth (Phase 1)
AUTH_SECRET=replace-with-32-byte-base64-secret

# Zero JWT verification (must equal AUTH_SECRET in production for issuance + verification)
ZERO_AUTH_SECRET=replace-with-32-byte-base64-secret
