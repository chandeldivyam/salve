# Hono API server
PORT=3001
NODE_ENV=development

# Postgres — host port is 5433 (5432 is commonly occupied by other projects on dev machines).
# Container is still :5432 internally; docker-compose maps 5433->5432.
DATABASE_URL=postgres://salve:salve@localhost:5433/salve

# Shared symmetric secret used to sign + verify the salve JWT (and consumed by zero-cache
# in Phase 2+). 32 bytes hex. Generate with: openssl rand -hex 32
AUTH_SECRET=replace-with-32-byte-hex-secret
ZERO_AUTH_SECRET=replace-with-32-byte-hex-secret

# better-auth runtime config
BETTER_AUTH_URL=http://localhost:3001
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:5173

# Inngest
INNGEST_DEV_URL=http://localhost:8288
INNGEST_EVENT_KEY=dev-key
INNGEST_SIGNING_KEY=
INNGEST_SERVE_ORIGIN=http://host.docker.internal:3001

# Delivery / email
# mailpit in local dev; ses or mailgun in production/staging.
MAILER_BACKEND=mailpit
MAILPIT_HOST=localhost
MAILPIT_PORT=1025
REPLY_DOMAIN=reply.usesalve.com
MAIL_FROM_SUBDOMAIN=mail

# AWS SES (used when MAILER_BACKEND=ses)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# SES SNS webhooks
SES_WEBHOOK_SECRET=
SES_SNS_AUTO_CONFIRM=0

# Mailgun (used when MAILER_BACKEND=mailgun). The signing key is *separate*
# from the API key — find it under Mailgun → Settings → API Security →
# "HTTP webhook signing key".
MAILGUN_API_KEY=
MAILGUN_WEBHOOK_SIGNING_KEY=
MAILGUN_API_BASE=https://api.mailgun.net
MAILGUN_SYSTEM_DOMAIN=mg.usesalve.com

# Mailgun inbound writes the raw RFC 5322 to S3 ourselves (SES does this for
# us; Mailgun forwards the body in the webhook). Falls back to S3_BUCKET when
# unset, but in prod this should be the dedicated raw-email bucket.
RAW_EMAIL_BUCKET=
