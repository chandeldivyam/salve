{
  "name": "@salve/cli",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "salve": "./dist/salve.mjs"
  },
  "files": [
    "README.md",
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/bin/salve.ts",
    "build": "tsdown",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "format": "biome format --write .",
    "check": "biome check .",
    "test": "tsx --test src/*.test.ts"
  },
  "dependencies": {
    "citty": "0.2.2",
    "cli-table3": "0.6.5",
    "picocolors": "1.1.1",
    "zod": "4.4.1"
  },
  "devDependencies": {
    "@salve/action-contracts": "workspace:*",
    "@salve/api-client": "workspace:*",
    "@types/node": "25.6.0",
    "tsdown": "0.21.10",
    "tsx": "4.21.0"
  }
}
